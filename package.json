{
  "name": "linespec",
  "version": "0.1.0",
  "description": "LineSpec DSL compiler for Keploy KTests and KMocks",
  "main": "dist/cli.js",
  "bin": {
    "linespec": "./dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "docs/**/*",
    "README.md",
    "LICENSE",
    "LINESPEC.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "ts-node src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "type": "commonjs",
  "keywords": [
    "linespec",
    "keploy",
    "testing",
    "mock",
    "mysql",
    "dsl",
    "compiler",
    "tdd"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/linespec.git"
  },
  "bugs": {
    "url": "https://github.com/anomalyco/linespec/issues"
  },
  "homepage": "https://github.com/anomalyco/linespec#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0",
    "@types/js-yaml": "^4.0.9",
    "ts-node": "^10.9.2",
    "vitest": "^1.2.0"
  }
}
