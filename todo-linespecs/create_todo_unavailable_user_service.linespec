TEST create_todo_unavailable_user_service

RECEIVE HTTP:POST /api/v1/todos
WITH {{payloads/create_todo_request.yaml}}

EXPECT HTTP:GET http://user-service.local/api/v1/users/auth
WITH {{payloads/auth_token_request.yaml}}
RETURNS {{payloads/unavailable_response.json}}

EXPECT NOT WRITE:MYSQL todos
WITH {{payloads/todo_insert.yaml}}

RESPOND HTTP:503
WITH {{payloads/unavailable_503.json}}
NOISE
  body.id