TEST list_todos_success

RECEIVE HTTP:GET /api/v1/todos
HEADERS
  Authorization: Bearer token_abc123xyz

EXPECT HTTP:GET http://user-service.local/api/v1/users/auth
HEADERS
  Authorization: Bearer token_abc123xyz
RETURNS {{payloads/authenticated_user.yaml}}

EXPECT READ:MYSQL todos
USING_SQL """
SELECT * FROM `todos` WHERE `todos`.`user_id` = 42
"""
RETURNS {{payloads/todos_list.yaml}}

RESPOND HTTP:200
WITH {{payloads/todos_list.yaml}}