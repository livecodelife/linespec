TEST test-8
RECEIVE HTTP:GET http://localhost:3000/todos/3

# Get single todo by ID (pattern matched by table name)
EXPECT READ:MYSQL todos
RETURNS {{payloads/mysql_todo_single_read_result.yaml}}

RESPOND HTTP:200
WITH {{payloads/todo_single_resp.yaml}}
NOISE
  body.id
  body.created_at
  body.updated_at
