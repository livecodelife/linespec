TEST test-4
RECEIVE HTTP:PATCH http://localhost:3000/users/3
WITH {{payloads/user_update_req.yaml}}

# Rails loads the user first (pattern matched by table name)
EXPECT READ:MYSQL users
RETURNS {{payloads/mysql_user_single_read_result.yaml}}

# Rails email uniqueness validation - must use exact SQL for specific condition
EXPECT READ:MYSQL users
USING_SQL """
SELECT 1 AS one FROM `users` WHERE `users`.`email` = 'Y95Eo@hTwDuyMmEWomNvmWRXfjUEr.cyy' AND `users`.`id` != 3 LIMIT 1
"""
RETURNS {{payloads/mysql_empty_result.yaml}}

# The actual UPDATE - VERIFY ensures password is hashed (no plain text)
EXPECT WRITE:MYSQL users
WITH {{payloads/mysql_users_update_req.yaml}}
VERIFY query NOT_CONTAINS 'something'

RESPOND HTTP:200
WITH {{payloads/user_update_resp.yaml}}
NOISE
  body.id
  body.created_at
  body.updated_at
