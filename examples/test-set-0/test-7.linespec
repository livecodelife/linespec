TEST test-7
RECEIVE HTTP:GET http://localhost:3000/todos/user/3

# Rails validates the user exists first (pattern matched by table name)
EXPECT READ:MYSQL users
RETURNS {{payloads/mysql_user_single_read_result.yaml}}

# Then queries todos for that user (needs WHERE clause for user_id filter)
EXPECT READ:MYSQL todos
USING_SQL """
SELECT `todos`.* FROM `todos` WHERE `todos`.`user_id` = 3
"""
RETURNS {{payloads/mysql_todos_read_result.yaml}}

RESPOND HTTP:200
WITH {{payloads/todos_list_resp.yaml}}
NOISE
  body.id
  body.created_at
  body.updated_at
