TEST update_todo_success

RECEIVE HTTP:PATCH /api/v1/todos/1
WITH {{payloads/update_todo_request.yaml}}
HEADERS
  Authorization: Bearer ${AUTH_TOKEN}

EXPECT HTTP:GET http://user-service.local/api/v1/users/auth
HEADERS
  Authorization: Bearer ${AUTH_TOKEN}
RETURNS {{payloads/authenticated_user.yaml}}

EXPECT READ:MYSQL todos
USING_SQL """
SELECT * FROM `todos` WHERE `todos`.`id` = 1 AND `todos`.`user_id` = 42 LIMIT 1
"""
RETURNS {{payloads/todo_single.yaml}}

EXPECT WRITE:MYSQL todos
WITH {{payloads/todo_update.yaml}}

EXPECT EVENT:todo-events
WITH {{payloads/todo_updated_event.yaml}}

RESPOND HTTP:200
WITH {{payloads/updated_todo.yaml}}
NOISE
  body.updated_at